# --- Runtime mode -------------------------------------------------------------
# mock      : payments simulated in-process (deterministic demo, no wallet needed)
# injective : real USDC on Injective EVM testnet — x402 payments, on-chain
#             ruling anchors (TruthOracle) and pool payouts (ParametricPool)
PAYMENT_RAIL=mock

# --- Match data mode ------------------------------------------------------------
# replay : recorded real match (Argentina 3-2 Egypt, R16), deterministic
#          (default; best for filming — one juror can be compromised on cue)
# live   : real 2026 FIFA World Cup data. Jurors query genuinely independent
#          providers (ESPN scoreboard / TheSportsDB / football-data.org or
#          ESPN summary), and the Scout polls the live feed for new goals.
MATCH_MODE=replay
# live mode options:
# LIVE_DATE=20260706          # YYYYMMDD, default: today (UTC)
# LIVE_TEAM=Argentina         # pick the match containing this team; else first match of the day
# AUTO_ADJUDICATE=true        # adjudicate new goals the moment the live feed reports them
# LIVE_POLL_MS=45000          # live feed polling interval
# FOOTBALL_DATA_KEY=          # optional, free at football-data.org — gives juror-3 a third independent provider
# THESPORTSDB_KEY=123         # optional, defaults to the free tier key

# --- The ONE key you must provide (injective mode) -----------------------------
# A wallet on Injective EVM Testnet (chain 1439) holding:
#   - testnet INJ  → https://testnet.faucet.injective.network
#   - testnet USDC → https://faucet.circle.com (select "Injective Testnet")
# Copy this file to .env and paste the private key here. Everything else below
# is generated and funded automatically by `npm run setup`.
FUNDER_PRIVATE_KEY=

# --- Generated by `npm run setup` (do not fill by hand) ------------------------
FACILITATOR_PRIVATE_KEY=
ARBITER_PRIVATE_KEY=
TREASURER_PRIVATE_KEY=
CONSUMER_PRIVATE_KEY=
JUROR_1_PRIVATE_KEY=
JUROR_2_PRIVATE_KEY=
JUROR_3_PRIVATE_KEY=
BENEFICIARY_PRIVATE_KEY=
BENEFICIARY_ADDRESS=

# --- Contracts (written to deployments.json by `npm run deploy`) ---------------
# Payout size of the ParametricPool term, in USDC (deploy-time constant)
POOL_PAYOUT_USDC=1

# --- CCTP cross-chain funding (optional, `npm run cctp`) -----------------------
# The FUNDER wallet also needs USDC + ETH on Ethereum Sepolia
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# --- LLM reasoning (optional) ---------------------------------------------------
# If set, juror rationale, cross-examination answers and VAR announcements are
# generated by an OpenAI-compatible chat completions API. If unset, a
# deterministic scripted fallback is used (recommended while filming).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Server ---------------------------------------------------------------------
PORT=4402
# Used by the MCP server and the arbiter's x402 client to reach this instance
VAR_URL=http://localhost:4402
# Optional RPC override. NOTE: the official k8s endpoint does not serve
# eth_getTransactionReceipt (always null), which breaks x402 settlement
# confirmation — polkachu's public RPC works correctly.
INJECTIVE_RPC_URL=https://injectiveevm-testnet-rpc.polkachu.com
