{
  "version": 2,
  "builds": [{ "src": "public/**", "use": "@vercel/static" }],
  "routes": [
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/observatory", "dest": "/public/observatory.html" },
    { "src": "/dashboard", "dest": "/public/dashboard.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
